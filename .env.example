# db-mcp Environment Configuration
# Copy this file to .env and update the values for your environment

# ==========================================
# Server Configuration
# ==========================================
# MCP_HOST=0.0.0.0                  # Host/IP to bind to (CLI: --server-host)
# LOG_LEVEL=info                    # Log verbosity: debug, info, warning, error
# METADATA_CACHE_TTL_MS=5000        # Schema cache TTL in ms (auto-invalidated on DDL operations)
# CODEMODE_ISOLATION=worker         # Code Mode sandbox: worker (enhanced isolation) or vm
# CODE_MODE_MAX_RESULT_SIZE=102400  # Max Code Mode result payload in bytes (default 100KB, cap 50MB)
# MCP_RATE_LIMIT_MAX=100            # Max requests/minute per IP (HTTP transport)

# ==========================================
# Database Configuration
# ==========================================
# SQLITE_DATABASE=./database.db     # SQLite database path (CLI: --sqlite / --sqlite-native)

# ==========================================
# Tool Filtering
# ==========================================
# DB_MCP_TOOL_FILTER=codemode       # Tool filter string (CLI: --tool-filter)

# ==========================================
# Extensions (Native Backend Only)
# ==========================================
# CSV_EXTENSION_PATH=/path/to/csv.so             # Custom path to CSV extension binary
# SPATIALITE_PATH=/path/to/mod_spatialite.so     # Custom path to SpatiaLite extension binary

# ==========================================
# Authentication (OAuth 2.1 & Token)
# ==========================================
# MCP_AUTH_TOKEN=your-secret-token  # Simple bearer token for HTTP auth (CLI: --auth-token)
# OAUTH_ENABLED=false               # Enable OAuth 2.1 (CLI: --oauth-enabled)
# OAUTH_ISSUER=http://localhost:8080/realms/db-mcp # Authorization server URL (CLI: --oauth-issuer)
# OAUTH_AUDIENCE=db-mcp-server      # Expected token audience (CLI: --oauth-audience)
# OAUTH_JWKS_URI=                   # JWKS URI, auto-discovered if omitted (CLI: --oauth-jwks-uri)
# OAUTH_CLOCK_TOLERANCE=60          # Clock tolerance in seconds (CLI: --oauth-clock-tolerance)

# ==========================================
# Audit Logging Configuration
# ==========================================
# AUDIT_LOG=./audit.jsonl           # File path or "stderr" (omit to disable)
# AUDIT_REDACT=false                # Redact tool arguments from audit entries
# AUDIT_READS=false                 # Also log read-scoped tool invocations
# AUDIT_BACKUP=false                # Enable pre-mutation DDL snapshots
# AUDIT_BACKUP_DATA=false           # Include sample data rows in snapshots

# ==========================================
# Docker & Dev Scripts Configuration
# ==========================================
# These are used by docker-compose.yml and setup scripts
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=db-mcp
KEYCLOAK_CLIENT_ID=db-mcp-server
KEYCLOAK_CLIENT_SECRET=your_client_secret_here

DBMCP_PORT=3000
DBMCP_OAUTH_ENABLED=true

# Derived OAuth endpoints (usually don't need to change)
# OAUTH_TOKEN_ENDPOINT=${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/token

# Test User (development only - set your own values)
# TEST_USER=testuser
# TEST_PASSWORD=your_password_here
