# db-mcp OAuth Environment Configuration
# Copy this file to .env and update the values for your environment

# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=db-mcp
KEYCLOAK_CLIENT_ID=db-mcp-server
KEYCLOAK_CLIENT_SECRET=your_client_secret_here

# db-mcp Server Configuration
DBMCP_PORT=3000
DBMCP_OAUTH_ENABLED=true

# Derived OAuth endpoints (usually don't need to change)
# OAUTH_ISSUER=${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}
# OAUTH_JWKS_URI=${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/certs
# OAUTH_TOKEN_ENDPOINT=${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/token

# Test User (development only - set your own values)
# TEST_USER=testuser
# TEST_PASSWORD=your_password_here

# Audit Logging Configuration
# AUDIT_LOG=./audit.jsonl           # File path or "stderr" (omit to disable)
# AUDIT_REDACT=false                # Redact tool arguments from audit entries
# AUDIT_READS=false                 # Also log read-scoped tool invocations
# AUDIT_BACKUP=false                # Enable pre-mutation DDL snapshots
# AUDIT_BACKUP_DATA=false           # Include sample data rows in snapshots
