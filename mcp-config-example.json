{
  "mcpServers": {
    "db-mcp": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-v",
        "./data:/app/data",
        "-e",
        "MCP_HOST",
        "-e",
        "LOG_LEVEL",
        "-e",
        "METADATA_CACHE_TTL_MS",
        "-e",
        "CODEMODE_ISOLATION",
        "-e",
        "CODE_MODE_MAX_RESULT_SIZE",
        "-e",
        "MCP_RATE_LIMIT_MAX",
        "-e",
        "SQLITE_DATABASE",
        "-e",
        "DB_MCP_TOOL_FILTER",
        "-e",
        "CSV_EXTENSION_PATH",
        "-e",
        "SPATIALITE_PATH",
        "-e",
        "MCP_AUTH_TOKEN",
        "-e",
        "OAUTH_ENABLED",
        "-e",
        "OAUTH_ISSUER",
        "-e",
        "OAUTH_AUDIENCE",
        "-e",
        "OAUTH_JWKS_URI",
        "-e",
        "OAUTH_CLOCK_TOLERANCE",
        "-e",
        "AUDIT_BACKUP",
        "-e",
        "AUDIT_REDACT",
        "-e",
        "AUDIT_READS",
        "-e",
        "AUDIT_BACKUP_DATA",
        "-e",
        "AUDIT_LOG",
        "writenotenow/db-mcp:latest",
        "--sqlite-native",
        "/app/data/my-database.db",
        "--tool-filter",
        "codemode",
        "--audit-log",
        "/tmp/db-mcp-logs/audit.jsonl"
      ],
      "env": {
        "MCP_HOST": "0.0.0.0",
        "LOG_LEVEL": "info",
        "METADATA_CACHE_TTL_MS": "5000",
        "CODEMODE_ISOLATION": "worker",
        "CODE_MODE_MAX_RESULT_SIZE": "",
        "MCP_RATE_LIMIT_MAX": "100",
        "SQLITE_DATABASE": "",
        "DB_MCP_TOOL_FILTER": "",
        "CSV_EXTENSION_PATH": "",
        "SPATIALITE_PATH": "",
        "MCP_AUTH_TOKEN": "",
        "OAUTH_ENABLED": "false",
        "OAUTH_ISSUER": "",
        "OAUTH_AUDIENCE": "",
        "OAUTH_JWKS_URI": "",
        "OAUTH_CLOCK_TOLERANCE": "60",
        "AUDIT_BACKUP": "false",
        "AUDIT_REDACT": "false",
        "AUDIT_READS": "false",
        "AUDIT_BACKUP_DATA": "false",
        "AUDIT_LOG": ""
      }
    }
  }
}
