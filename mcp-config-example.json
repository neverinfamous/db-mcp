{
  "mcpServers": {
    "db-mcp": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-v",
        "./data:/app/data",
        "-e",
        "MCP_HOST",
        "-e",
        "LOG_LEVEL",
        "-e",
        "METADATA_CACHE_TTL_MS",
        "-e",
        "CODEMODE_ISOLATION",
        "-e",
        "CODE_MODE_MAX_RESULT_SIZE",
        "-e",
        "MCP_RATE_LIMIT_MAX",
        "-e",
        "SQLITE_DATABASE",
        "-e",
        "DB_ENCRYPTION_KEY",
        "-e",
        "DB_MCP_TOOL_FILTER",
        "-e",
        "METRICS_EXPORT",
        "-e",
        "CSV_EXTENSION_PATH",
        "-e",
        "SPATIALITE_PATH",
        "-e",
        "MCP_AUTH_TOKEN",
        "-e",
        "OAUTH_ENABLED",
        "-e",
        "OAUTH_ISSUER",
        "-e",
        "OAUTH_AUDIENCE",
        "-e",
        "OAUTH_JWKS_URI",
        "-e",
        "OAUTH_CLOCK_TOLERANCE",
        "-e",
        "MCP_ENABLE_HSTS",
        "-e",
        "NO_AUTH_ENFORCEMENT",
        "-e",
        "AUDIT_BACKUP",
        "-e",
        "AUDIT_REDACT",
        "-e",
        "AUDIT_READS",
        "-e",
        "AUDIT_BACKUP_DATA",
        "-e",
        "AUDIT_LOG",
        "writenotenow/db-mcp:latest",
        "--sqlite-native",
        "/app/data/my-database.db",
        "--encryption-key",
        "your-strong-passphrase-here",
        "--tool-filter",
        "codemode",
        "--metrics-export",
        "prometheus",
        "--audit-log",
        "/tmp/db-mcp-logs/audit.jsonl"
      ],
      "env": {
        "MCP_HOST": "0.0.0.0",
        "LOG_LEVEL": "info",
        "METADATA_CACHE_TTL_MS": "5000",
        "CODEMODE_ISOLATION": "isolate",
        "CODE_MODE_MAX_RESULT_SIZE": "102400",
        "MCP_RATE_LIMIT_MAX": "100",
        "SQLITE_DATABASE": "/app/data/my-database.db",
        "DB_ENCRYPTION_KEY": "your-strong-passphrase-here",
        "DB_MCP_TOOL_FILTER": "codemode",
        "METRICS_EXPORT": "prometheus",
        "CSV_EXTENSION_PATH": "/path/to/csv.so",
        "SPATIALITE_PATH": "/path/to/mod_spatialite.so",
        "MCP_AUTH_TOKEN": "your-secret-token",
        "OAUTH_ENABLED": "false",
        "OAUTH_ISSUER": "http://localhost:8080/realms/mcp",
        "OAUTH_AUDIENCE": "account",
        "OAUTH_JWKS_URI": "http://localhost:8080/realms/mcp/protocol/openid-connect/certs",
        "OAUTH_CLOCK_TOLERANCE": "60",
        "MCP_ENABLE_HSTS": "false",
        "NO_AUTH_ENFORCEMENT": "false",
        "AUDIT_BACKUP": "false",
        "AUDIT_REDACT": "false",
        "AUDIT_READS": "false",
        "AUDIT_BACKUP_DATA": "false",
        "AUDIT_LOG": "/tmp/db-mcp-logs/audit.jsonl"
      }
    }
  }
}
